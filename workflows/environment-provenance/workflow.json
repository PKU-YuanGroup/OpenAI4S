{
  "id": "environment-provenance",
  "version": "1.0.0",
  "title": "产物环境 provenance",
  "summary": "产物必须记录**实际产生它的内核代际**，而不是 daemon 自己的解释器。",
  "steps": [
    "open_session",
    "register_kernel_generation",
    "capture_environment"
  ],
  "permissions": [
    "kernel:python"
  ],
  "artifacts": [],
  "failure_conditions": [
    "快照记录了 daemon 而不是内核",
    "代际归属不可验证却未标注"
  ],
  "cases": [
    {
      "id": "environment-provenance/measured",
      "title": "有内核代际时快照标记为 verified",
      "outcome": "provenance",
      "inputs": {
        "register_kernel_generation": {
          "language": "python",
          "interpreter": "/opt/bench/bin/python",
          "environment_name": "bench-env"
        }
      },
      "expect": {
        "kind": "python",
        "generation_confidence": "verified"
      }
    },
    {
      "id": "environment-provenance/assumed",
      "title": "无内核代际时必须明说是假定的",
      "outcome": "provenance",
      "inputs": {
        "register_kernel_generation": {
          "language": "r",
          "interpreter": "/usr/bin/Rscript",
          "environment_name": "r-bench"
        },
        "capture_environment": {
          "language": "python"
        }
      },
      "expect": {
        "generation_confidence": null,
        "provenance__contains": "assumed"
      }
    }
  ]
}
