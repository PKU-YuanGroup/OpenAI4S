# Ship the default conda env specs and the setup wrapper in the sdist so
# `openai4s setup` (and scripts/setup_envs.sh) work from a source distribution.
include envs/*.yml
include CODE_OF_CONDUCT.md
include SECURITY.md
include scripts/setup_envs.sh
include scripts/*.py
recursive-include docs *.md
recursive-include skills *.html *.json *.lock *.md *.py
recursive-include workflows *.json
recursive-include openai4s/compute/templates *.tmpl
recursive-include openai4s/kernel *.R
recursive-include openai4s/server/webui *.css *.gif *.html *.js *.woff2
global-exclude *.py[cod]
global-exclude __pycache__
